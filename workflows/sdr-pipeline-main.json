    {
      "id": "a1b2c3d4-0020-0020-0020-000000000020",
      "name": "Build Approval Links",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2220,
        540
      ],
      "parameters": {
        "jsCode": "// Telegram rechaza URLs localhost en botones inline — se necesita la URL\n// publica del tunel (scripts/start-tunnel.sh) para que Aprobar/Rechazar\n// funcionen desde cualquier dispositivo.\nconst lead = items[0].json;\n\nlet publicBase;\ntry {\n  const res = await this.helpers.httpRequest({\n    url: 'http://host.docker.internal:20241/quicktunnel',\n    json: true,\n    timeout: 3000,\n  });\n  if (res && res.hostname) publicBase = 'https://' + res.hostname;\n} catch (e) {\n  // sin tunel: error claro mas abajo\n}\n\nif (!publicBase) {\n  throw new Error('Tunel no disponible. Correr scripts/start-tunnel.sh antes de disparar leads — Telegram no acepta botones apuntando a localhost.');\n}\n\nconst resume = $execution.resumeUrl.replace(/^https?:\\/\\/[^/]+/, publicBase);\n\nreturn [{\n  json: {\n    ...lead,\n    approve_url: resume + '&action=approve',\n    reject_url: resume + '&action=reject',\n  },\n}];"
      },
      "notes": "Descubre la URL publica del quick tunnel (endpoint /quicktunnel de metricas de cloudflared) y reescribe el resumeUrl para los botones de Telegram. Preserva el item del lead. Falla con mensaje claro si el tunel no corre."
    }
