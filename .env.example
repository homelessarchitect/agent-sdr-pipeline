# n8n core
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# API keys
OPENAI_API_KEY=sk-...
HUNTER_API_KEY=...
RESEND_API_KEY=re_...
HUBSPOT_ACCESS_TOKEN=pat-...

# Telegram (chat ID only — bot token lives in n8n credential UI)
TELEGRAM_CHAT_ID=...

# Calendar booking link — injected as CTA in outreach emails (no integration needed)
CALENDLY_LINK=https://calendly.com/your-link

# n8n Public REST API key — generate in n8n UI: Settings > n8n API > Create API key
N8N_API_KEY=

# Demo email override — Resend free tier with onboarding@resend.dev only delivers
# to the account owner inbox. Set this to YOUR real email to test email delivery.
# Leave empty to skip (lead email stored in CRM regardless).
DEMO_EMAIL_OVERRIDE=
